import sys
import numpy as np
import sounddevice as sd
import threading
import keyboard
import collections
from PyQt6.QtWidgets import QApplication, QWidget
from PyQt6.QtCore import Qt, QTimer, QRectF
from PyQt6.QtGui import QPainter, QColor, QFont, QPen

# --- CONFIGURACIÓN TÉCNICA Y PARÁMETROS DE INGENIERÍA ---
TAMANO_BUFFER = 2048        # Mayor resolución de frecuencia
CANALES = 2                 # Estéreo (L/R)
TASA_MUESTREO = 44100

FRECUENCIA_MINIMA_PASO = 200 
FRECUENCIA_MAXIMA_PASO = 600 

SENSIBILIDAD_INICIAL = 1.0

class BruljaSonoraHud(QWidget):
    """
    Radar HUD (Brújula) en el centro de la pantalla. Detecta transigentes
    de baja/media frecuencia usando FFT + Noise Gate y dibuja un arco 
    direccional en pantalla que se desvanece suavemente (Lerp).
    """
    def __init__(self):
        super().__init__()
        # Configuración dinámica (Atajos)
        self.sensibilidad_global = SENSIBILIDAD_INICIAL
        self.mensaje_temporal_ui = ""
        self.tiempo_mensaje_restante = 0

        # Historial de ruido de fondo para el Noise Gate
        self.historial_ruido = collections.deque(maxlen=20)
        self.promedio_fondo = 0.0

        # Estado del Audio actual procesado
        self.angulo_sonido_objetivo = 90  # 90 grados es centro arriba
        self.intensidad_sonido_objetivo = 0.0
        
        # Variables para Lerp visual (Suavizado de la GUI)
        self.angulo_dibujado = 90.0
        self.opacidad_dibujada = 0.0

        self.iniciar_interfaz_usuario()
        self.iniciar_controles_teclado()
        
        # Hilo de Audio independiente (Productor)
        self.hilo_audio = threading.Thread(target=self.procesar_senales_audio, daemon=True)
        self.hilo_audio.start()

        # Timer gráfico (60 FPS - Consumidor)
        self.temporizador = QTimer()
        self.temporizador.timeout.connect(self.actualizar_fisicas_y_repintar)
        self.temporizador.start(16)

    def iniciar_interfaz_usuario(self):
        self.setWindowFlags(Qt.WindowType.FramelessWindowHint | 
                            Qt.WindowType.WindowStaysOnTopHint | 
                            Qt.WindowType.WindowTransparentForInput)
        self.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground)
        
        # Ubicar una ventana de 400x400 en el centro exacto del monitor principal
        pantalla_completa = QApplication.primaryScreen().geometry()
        x_centro = (pantalla_completa.width() - 400) // 2
        y_centro = (pantalla_completa.height() - 400) // 2
        self.setGeometry(x_centro, y_centro, 400, 400)

    def iniciar_controles_teclado(self):
        # Hooks asíncronos verificados que no colisionan con tu SO
        keyboard.add_hotkey("ctrl+up", self.subir_sensibilidad)
        keyboard.add_hotkey("ctrl+down", self.bajar_sensibilidad)
        
        # Opciones secundarias si prefieres usar una sola mano (RePág / AvPág)
        keyboard.add_hotkey("page up", self.subir_sensibilidad)
        keyboard.add_hotkey("page down", self.bajar_sensibilidad)

    def subir_sensibilidad(self, *_):
        self.sensibilidad_global += 0.2
        self.disparar_mensaje_osd(f"SENSIBILIDAD: {self.sensibilidad_global:.1f}x")

    def bajar_sensibilidad(self, *_):
        self.sensibilidad_global = max(0.2, self.sensibilidad_global - 0.2)
        self.disparar_mensaje_osd(f"SENSIBILIDAD: {self.sensibilidad_global:.1f}x")

    def disparar_mensaje_osd(self, mensaje):
        self.mensaje_temporal_ui = mensaje
        self.tiempo_mensaje_restante = 120  # ~2 segundos visible a 60 FPS

    def procesar_senales_audio(self):
        try:
            # Inicializar el buffer circular nativo usando SoundDevice (que omite la compilación de C++)
            flujo_audio = sd.InputStream(samplerate=TASA_MUESTREO, 
                                         channels=CANALES, 
                                         blocksize=TAMANO_BUFFER, 
                                         dtype='int16')
            flujo_audio.start()
        except Exception as error_inicializacion:
            print(f"Error nativo al capturar mezcla de estéreo: {error_inicializacion}")
            return

        frecuencias_banda = np.fft.rfftfreq(TAMANO_BUFFER, 1 / TASA_MUESTREO)
        indices_pasos = np.where((frecuencias_banda >= FRECUENCIA_MINIMA_PASO) & 
                                 (frecuencias_banda <= FRECUENCIA_MAXIMA_PASO))[0]

        while True:
            try:
                # Lectura sincrónica: datos nativos entregados directo a NumPy array 2D
                datos_numericos, control_overflow = flujo_audio.read(TAMANO_BUFFER)
                
                if control_overflow:
                    continue # Omite si la lectura está enconada
                
                # Desentrelazar: Columna 0 (Left), Columna 1 (Right) y FFT
                canal_izquierdo = np.abs(np.fft.rfft(datos_numericos[:, 0]))
                canal_derecho = np.abs(np.fft.rfft(datos_numericos[:, 1]))

                energia_l = float(np.mean(canal_izquierdo[indices_pasos]))
                energia_r = float(np.mean(canal_derecho[indices_pasos]))
                energia_total = (energia_l + energia_r) * self.sensibilidad_global

                # NOISE GATE (Supresión Cíclica Activa)
                if len(self.historial_ruido) >= 20:
                    self.promedio_fondo = np.mean(self.historial_ruido)
                else:
                    self.promedio_fondo = energia_total + 1.0

                UMBRAL_RUIDO_AMB = self.promedio_fondo * 1.5 
                
                # Evaluación de Transitorio y Ángulo de Paneo
                if energia_total > UMBRAL_RUIDO_AMB and energia_total > 50.0:
                    balance = energia_r / (energia_l + energia_r + 1e-6)
                    self.angulo_sonido_objetivo = 180.0 - (balance * 180.0)
                    self.intensidad_sonido_objetivo = min(1.0, energia_total / (UMBRAL_RUIDO_AMB * 3.0)) 
                else:
                    self.historial_ruido.append(energia_total)
                    self.intensidad_sonido_objetivo = 0.0

            except Exception as e:
                import traceback; traceback.print_exc()
                continue

    def actualizar_fisicas_y_repintar(self):
        velocidad_animacion_caida = 0.05
        velocidad_animacion_ataque = 0.4
        
        # Filtros LERP de aceleración matemática para dibujo sin "popping"
        coeff = velocidad_animacion_ataque if self.intensidad_sonido_objetivo > self.opacidad_dibujada else velocidad_animacion_caida
        self.opacidad_dibujada += (self.intensidad_sonido_objetivo - self.opacidad_dibujada) * coeff
        
        dif_angular = self.angulo_sonido_objetivo - self.angulo_dibujado
        if abs(dif_angular) > 0.5:
            self.angulo_dibujado += dif_angular * 0.15

        if self.tiempo_mensaje_restante > 0:
            self.tiempo_mensaje_restante -= 1

        self.update() 

    def paintEvent(self, evento_pintado):
        pintor = QPainter(self)
        pintor.setRenderHint(QPainter.RenderHint.Antialiasing)

        centro = self.rect().center()
        radio_externo = 120
        radio_interno = 100

        # -- Dibujar Mirilla Frontal (Base DashLine) --
        pintor.setPen(QPen(QColor(255, 255, 255, 30), 1, Qt.PenStyle.DashLine))
        pintor.drawEllipse(centro, radio_interno, radio_interno)
        
        # -- Dibujar Arco Dinámico FFT (Radar de Pasos) --
        if self.opacidad_dibujada > 0.02:
            opacidad_rgba = min(255, int(self.opacidad_dibujada * 255 * 1.5))
            lapiz_alerta = QPen(QColor(0, 255, 100, opacidad_rgba), 15, Qt.PenStyle.SolidLine, Qt.PenCapStyle.RoundCap)
            pintor.setPen(lapiz_alerta)
            
            rectangulo_dibujo = QRectF(centro.x() - radio_externo, centro.y() - radio_externo, 
                                       radio_externo * 2, radio_externo * 2)
            
            apertura_conica = 40 
            angulo_dibujo_qt = int((self.angulo_dibujado - (apertura_conica / 2)) * 16)
            longitud_dibujo_qt = int(apertura_conica * 16)
            
            pintor.drawArc(rectangulo_dibujo, angulo_dibujo_qt, longitud_dibujo_qt)

        # -- UI OSD --
        if self.tiempo_mensaje_restante > 0:
            pintor.setPen(Qt.GlobalColor.white)
            fuente_osd = QFont('Consolas', 11, QFont.Weight.Bold)
            pintor.setFont(fuente_osd)
            alpha_texto = min(255, self.tiempo_mensaje_restante * 5)
            pintor.setPen(QColor(255, 255, 255, alpha_texto))
            
            texto_rect = QRectF(0, centro.y() + radio_externo + 20, 400, 30)
            pintor.drawText(texto_rect, Qt.AlignmentFlag.AlignCenter, self.mensaje_temporal_ui)

if __name__ == "__main__":
    aplicacion_qt = QApplication(sys.argv)
    ventana_rada = BruljaSonoraHud()
    ventana_rada.show()
    sys.exit(aplicacion_qt.exec())