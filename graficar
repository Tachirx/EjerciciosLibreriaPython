import pandas as pd
import matplotlib.pyplot as plt

try:
    # Cargar los datos recolectados
    df = pd.read_csv('registro_internet.csv')
    df['Fecha_Hora'] = pd.to_datetime(df['Fecha_Hora'])
    
    # Estilo visual tipo "Hacker / Dark Mode"
    plt.style.use('dark_background')
    plt.figure(figsize=(12, 6))
    
    # Separar cuando hay internet de cuando se cae
    online = df[df['Estado'] == 'Online']
    offline = df[df['Estado'] == 'Offline']
    
    # Dibujar la línea de lag (Ping)
    plt.plot(online['Fecha_Hora'], online['Ping_ms'], color='#00ffcc', label='Latencia (ms)', linewidth=1.5)
    plt.fill_between(online['Fecha_Hora'], online['Ping_ms'], color='#00ffcc', alpha=0.2)
    
    # Trazar barras rojas donde el internet se cayó
    for idx, row in offline.iterrows():
         plt.axvline(x=row['Fecha_Hora'], color='#ff3333', alpha=0.6, linestyle='--')
         
    plt.title('Reporte de Estabilidad de Red', fontsize=16, weight='bold')
    plt.xlabel('Línea de Tiempo')
    plt.ylabel('Milisegundos (ms)')
    
    # Añadir un indicador a la leyenda para las caídas
    import matplotlib.lines as mlines
    linea_caida = mlines.Line2D([], [], color='#ff3333', linestyle='--', label='Desconexión de Red')
    plt.legend(handles=[plt.Line2D([0], [0], color='#00ffcc', lw=2, label='Ping (ms)'), linea_caida])
    
    plt.grid(True, alpha=0.2, linestyle=':')
    plt.tight_layout()
    
    # Mostrar la gráfica interactiva en pantalla
    plt.show()
    
except Exception as e:
    print("Hubo un error al generar la gráfica.")
    print("Detalle:", e)